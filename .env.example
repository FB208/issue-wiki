# 应用基础配置
APP_NAME=Issue Wiki
ENV=production
API_PREFIX=/api
CORS_ORIGINS=https://your-domain.com
GITHUB_PROJECT_URL=https://github.com/your-org/your-project
# 本站服务的开源项目名称，用于左下角链接文案，留空则显示“服务的开源项目”
GITHUB_PROJECT_NAME=
GITHUB_SYNC_ENABLED=false
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_BASE_URL=https://api.github.com

# 数据库和缓存连接
DATABASE_URL=mysql+pymysql://issue_wiki:change-me@mysql-host:3306/issue_wiki?charset=utf8mb4
REDIS_URL=redis://redis-host:6379/0

# 登录令牌配置，JWT_SECRET 生产环境必须改成随机长字符串
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_DAYS=3650

# 初始化管理员账号
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_NICKNAME=生产力Mark

# 当前启用支付渠道：xorpay 或 afdian
PAYMENT_CHANNEL=xorpay

# XorPay 微信扫码支付配置
# XORPAY_AID 和 XORPAY_APP_SECRET 在 XorPay 后台配置页获取
XORPAY_AID=replace-with-xorpay-aid
XORPAY_APP_SECRET=replace-with-xorpay-app-secret
# 回调地址必须公网可访问；本地开发调试需要内网穿透
XORPAY_NOTIFY_URL=https://your-domain.com/api/payments/xorpay/notify
# 用户在赞助弹窗中可提交的最低金额
XORPAY_MIN_ORDER_AMOUNT=1.00
XORPAY_API_BASE_URL=https://xorpay.com
XORPAY_ORDER_EXPIRE_SECONDS=7200

# 爱发电赞助配置，PAYMENT_CHANNEL=afdian 时启用
# AFDIAN_SPONSOR_URL 填写你的爱发电主页或赞助页地址，前端“前往爱发电赞助”会跳转到这里
AFDIAN_SPONSOR_URL=https://afdian.com/a/your-name
# webhook 地址建议配置为：https://your-domain.com/api/payments/afdian/webhook?secret=replace-with-webhook-secret
AFDIAN_WEBHOOK_SECRET=replace-with-webhook-secret
# 开发者 API 配置保留给后续历史订单同步/主动校验使用，可在 https://afdian.com/dashboard/dev 获取
AFDIAN_USER_ID=
AFDIAN_API_TOKEN=
AFDIAN_API_BASE_URL=https://afdian.net/api/open

# Gmail SMTP 邮箱验证码配置
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USERNAME=your-gmail@gmail.com
GMAIL_PASSWORD=your-gmail-app-password
GMAIL_FROM=your-gmail@gmail.com

# 阿里云短信验证码配置
ALIYUN_ACCESS_KEY_ID=replace-with-access-key-id
ALIYUN_ACCESS_KEY_SECRET=replace-with-access-key-secret
# 短信使用阿里云号码认证服务赠送签名和赠送模板，代码内固定：速通互联验证码 / 100001

# RustFS 文件存储配置，兼容 S3 API
RUSTFS_ENDPOINT_URL=https://rustfs.example.com
RUSTFS_ACCESS_KEY_ID=replace-with-access-key
RUSTFS_SECRET_ACCESS_KEY=replace-with-secret-key
RUSTFS_BUCKET=issue-wiki
RUSTFS_PUBLIC_BASE_URL=https://static.example.com
RUSTFS_SECURE=true

# 上传和服务端口配置
UPLOAD_MAX_SIZE=10485760
# VSCode 调试端口从这两个值开始自动递增寻找可用端口
DEV_BACKEND_PORT=8000
DEV_FRONTEND_PORT=5173
# Docker 部署对外端口
APP_PORT=8000
