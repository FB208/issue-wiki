# GitHub Actions Repository Secrets 示例
#
# 使用方式：
# 在 GitHub 仓库打开：
# Settings -> Secrets and variables -> Actions -> Repository secrets -> New repository secret
#
# 下面这些变量都按当前 .github/workflows/deploy.yml 的写法配置到 Repository secrets。
# 服务器部署目录里的 .env 不在本文件维护，由你自行配置。
# 不要把真实密钥提交到仓库；本文件只保留占位值和说明。


# ============================================================
# 镜像仓库
# ============================================================

# 容器镜像仓库地址。
# 示例：
# - Docker Hub: docker.io
# - GitHub Container Registry: ghcr.io
# - 阿里云镜像仓库: registry.cn-hangzhou.aliyuncs.com
REGISTRY=ghcr.io

# 登录镜像仓库的用户名。
# 如果使用 ghcr.io，通常填写 GitHub 用户名。
REGISTRY_USERNAME=your-registry-username

# 登录镜像仓库的密码或访问令牌。
# 如果使用 ghcr.io，建议使用 GitHub PAT，并授予 packages 写入权限。
REGISTRY_PASSWORD=replace-with-registry-token

# 完整镜像仓库名，不带 tag。
# 当前 workflow 会推送：
# - ${REGISTRY_REPO}:${tag}
# - ${REGISTRY_REPO}:latest
#
# 示例：
# - ghcr.io/owner/issue-wiki
# - registry.cn-hangzhou.aliyuncs.com/namespace/issue-wiki
#
# 这个值本身不一定敏感，但当前 workflow 使用 secrets.REGISTRY_REPO 读取，
# 所以仍然需要配置到 Repository secrets。
REGISTRY_REPO=ghcr.io/owner/issue-wiki


# ============================================================
# SSH 部署服务器
# ============================================================

# 服务器 SSH 地址，可以是 IP 或域名。
SSH_HOST=your-server-ip-or-domain

# 服务器 SSH 用户名。
# 该用户需要能执行 docker、docker compose，并能访问 DEPLOY_DIR。
SSH_USER=root

# SSH 端口。默认 22；如果服务器改过端口，在这里填写实际端口。
SSH_PORT=22

# SSH 密码。
# 当前 workflow 使用 appleboy/ssh-action 的 password 登录方式；
# 如果要改成 SSH key，需要同步修改 .github/workflows/deploy.yml。
SSH_PASSWORD=replace-with-ssh-password

# 服务器部署目录。
# 该目录中必须存在 docker-compose.yml 和你自行维护的 .env。
# workflow 会在这里执行：
# VERSION="$VERSION" docker compose -f docker-compose.yml pull app
# VERSION="$VERSION" docker compose -f docker-compose.yml up -d --no-build app
DEPLOY_DIR=/opt/issue-wiki


# ============================================================
# 部署结果邮件通知
# ============================================================

# 部署结果通知邮件的发件 Gmail 账号。
# 当前 workflow 使用 dawidd6/action-send-mail。
GMAIL_USERNAME=your-gmail@gmail.com

# Gmail 应用专用密码，不是 Gmail 登录密码。
GMAIL_PASSWORD=replace-with-gmail-app-password

# 部署结果通知收件人。
GMAIL_TO=admin@example.com
