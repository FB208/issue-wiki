{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: prepare ports",
      "type": "shell",
      "command": "python scripts/dev_ports.py",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONUTF8": "1",
          "PYTHONIOENCODING": "utf-8"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "backend: install dependencies",
      "type": "shell",
      "command": "pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "PYTHONUTF8": "1",
          "PYTHONIOENCODING": "utf-8"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "backend: migrate",
      "type": "shell",
      "command": "alembic upgrade head",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/backend",
          "PYTHONUTF8": "1",
          "PYTHONIOENCODING": "utf-8"
        }
      },
      "dependsOn": [
        "backend: install dependencies"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "backend"
      }
    },
    {
      "label": "frontend: install dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend"
      }
    }
  ]
}
